{
  // Local typechecking only — Vercel compiles api/*.ts with its own settings.
  // moduleResolution is intentionally omitted: it defaults from `module`, and
  // setting it explicitly to node10 trips a deprecation warning in TS 6+.
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "types": ["node"]
  },
  "include": ["**/*.ts", "../server/src/**/*.ts"]
}
