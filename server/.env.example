# Copy to .env and fill in. NEVER commit .env — it is git-ignored.

PORT=5000

# Local: mongodb://localhost:27017/slotly
# Production: your Atlas SRV string. Use a dedicated demo user, not an admin.
MONGODB_URI=mongodb://localhost:27017/slotly

# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_me_with_a_long_random_string

# Only needed for the AI assistant — everything else runs without it, and the
# widget degrades to a polite message if it's missing.
# Free key from Google AI Studio: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Optional. Defaults to gemini-3.6-flash. Keep to a Flash model — as of April
# 2026 the Gemini free tier covers Flash and Flash-Lite only, not Pro.
GEMINI_MODEL=gemini-3.6-flash

# Enables `npm run seed` and the nightly demo reset. Keep false for real data —
# both operations DROP the database.
DEMO_MODE=true

# Shared secret for GET /api/cron/reset. Vercel Cron sends it automatically as
# `Authorization: Bearer $CRON_SECRET`. Generate the same way as JWT_SECRET.
CRON_SECRET=replace_me_with_a_long_random_string
